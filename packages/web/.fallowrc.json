{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/main.{ts,tsx,js,jsx}", "tests/setup.ts"],
  "ignorePatterns": ["src/components/ui/**", "src/routeTree.gen.ts", "src/api/schema.ts"],
  "ignoreDependencies": [
    "lucide-react",
    "@tanstack/react-router-devtools",
    "@tanstack/router-plugin",
    "class-variance-authority",
    "openapi-fetch"
  ],
  "ignoreExports": [
    {
      "file": "src/api/*",
      "exports": ["*"]
    }
  ],
  "rules": {
    "unused-dependencies": "warn",
    "unused-files": "error",
    "unused-exports": "warn",
    "unused-types": "off"
  }
}
