<Project>

  <PropertyGroup>
    <!--
      The .NET SDK's SourceLink target reads git internals (.git, .gitmodules) on every
      build to stamp the commit into the assembly. Under the local dev sandbox that read
      fails (Access to the path '.gitmodules' is denied), breaking the build. Skip the git
      query for local builds; CI (ContinuousIntegrationBuild=true) keeps SourceLink intact.
    -->
    <EnableSourceControlManagerQueries Condition="'$(ContinuousIntegrationBuild)' != 'true'">false</EnableSourceControlManagerQueries>
  </PropertyGroup>

</Project>
