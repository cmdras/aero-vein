# Single root .gitignore for the whole monorepo (packages/web + packages/api).
# Patterns are path-relative, so node_modules/, dist/, etc. match at any depth.

# Zone metadata files (Windows)
*.Zone.Identifier

# JS / bun (React frontend)
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
# Competing lockfiles — bun.lock is the committed source of truth, keep it tracked.
package-lock.json
yarn.lock
pnpm-lock.yaml
dist/
*.tsbuildinfo

# fallow cache
.fallow/

# Playwright (E2E) — generated artifacts and captured auth state
e2e/test-results/
e2e/playwright-report/
blob-report/
playwright/.cache/
e2e/.auth/

# .NET / C#
bin/
obj/
.vs/
*.user
*.suo
*.sln.docstates
*.userprefs
# Local-only / secret-bearing settings — developer-local, never committed.
appsettings.Local.json
appsettings.*.Local.json
appsettings.Development.json

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# Environment variables
.env
.env.local
.env.*.local

# OS files
Thumbs.db
.DS_Store
*.tmp

# Build outputs
build/
out/
*.log
