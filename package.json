{
  "name": "aero-vein",
  "private": true,
  "description": "The dispatch-and-operations brain for a same-day medical drone courier service",
  "workspaces": ["packages/*"],
  "type": "module",
  "scripts": {
    "dev": "bun run --filter 'web' dev",
    "dev:api": "dotnet watch run --project packages/api",
    "build:web": "bun run --filter 'web' build",
    "check": "bun run --filter '*' check",
    "test:web": "bun run --filter 'web' test --run",
    "test:api": "dotnet test aero-vein.slnx -m:1",
    "test:api:unit": "dotnet test packages/api.tests/api.tests.csproj -m:1",
    "test:api:int": "dotnet test packages/api.integration.tests/api.integration.tests.csproj -m:1",
    "test:e2e": "playwright test",
    "cleanup": "bun run --filter '*' cleanup"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.0",
    "rimraf": "^6.1.3",
    "vite-plus": "^0.1.20"
  },
  "packageManager": "bun@1.3.13"
}
